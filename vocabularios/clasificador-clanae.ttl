    dct:created "2026-06-03"^^xsd:date ;
    dct:modified "2026-06-03"^^xsd:date ;
    owl:versionInfo "0.1.0" .


# 1. ClaNAE 2010
#    Clasificador Nacional de Actividades Económicas
#    Fuente: INDEC — Disposición Nº 825/2010; Revisión 2017
#    Base: CIIU Revisión 4 (ONU)
#    Usos típicos: encuestas de empresas (ENGE, EMI, EIM, etc.)
# ================================================================

clanae:esquema
    a skos:ConceptScheme ;
    dct:title "ClaNAE 2010 — Clasificador Nacional de Actividades Económicas"@es ;
    dct:title "ClaNAE 2010 — National Classifier of Economic Activities"@en ;
    skos:prefLabel "ClaNAE 2010 — Clasificador Nacional de Actividades Económicas"@es ;
    skos:prefLabel "ClaNAE 2010 — National Classifier of Economic Activities"@en ;
    dct:description "Clasificador Nacional de Actividades Económicas 2010, adaptación argentina de la Clasificación Industrial Internacional Uniforme Revisión 4 (CIIU Rev.4) de las Naciones Unidas. Aprobado por INDEC mediante Disposición Nº 825/2010 y revisado en 2017."@es ;
    dct:source <https://www.indec.gob.ar/micro_sitios/clanae/default.asp> ;
    dct:source <https://www.indec.gob.ar/ftp/cuadros/economia/clanae_2010_revision_2017.pdf> ;
    dct:source <https://www.indec.gob.ar/ftp/cuadros/menusuperior/clasificadores/correspondencia_clanae2010_ciiu4.xls> ;
    dct:publisher <https://www.indec.gob.ar> ;
    dct:created "2010-01-01"^^xsd:date ;
    dct:modified "2017-11-17"^^xsd:date ;
    # Derivado de CIIU Rev.4 — mismo nivel de sección hasta clase
    xkos:belongsTo <https://unstats.un.org/unsd/classifications/Econ/isic#Rev4> ;
    # Estructura jerárquica: sección > división > grupo > clase > subclase
    xkos:levels (
        clanae:NivelSeccion
        clanae:NivelDivision
        clanae:NivelGrupo
        clanae:NivelClase
        clanae:NivelSubclase
    ) ;
    skos:hasTopConcept
        clanae:A , clanae:B , clanae:C , clanae:D , clanae:E ,
        clanae:F , clanae:G , clanae:H , clanae:I , clanae:J ,
        clanae:K , clanae:L , clanae:M , clanae:N , clanae:O ,
        clanae:P , clanae:Q , clanae:R , clanae:S , clanae:T ,
        clanae:U .

# Niveles jerárquicos
clanae:NivelSeccion  a xkos:ClassificationLevel ; skos:prefLabel "Sección"@es  ; xkos:depth 1 .
clanae:NivelDivision a xkos:ClassificationLevel ; skos:prefLabel "División"@es  ; xkos:depth 2 .
clanae:NivelGrupo    a xkos:ClassificationLevel ; skos:prefLabel "Grupo"@es     ; xkos:depth 3 .
clanae:NivelClase    a xkos:ClassificationLevel ; skos:prefLabel "Clase"@es     ; xkos:depth 4 .
clanae:NivelSubclase a xkos:ClassificationLevel ; skos:prefLabel "Subclase"@es  ; xkos:depth 5 .

# ── Secciones (nivel 1) ─────────────────────────────────────────
# Solo se modelan las secciones. Divisiones, grupos y clases
# están en el XLS oficial del INDEC y pueden incorporarse
# progresivamente como conceptos adicionales.

clanae:A
    a skos:Concept ; skos:inScheme clanae:esquema ;
    skos:topConceptOf clanae:esquema ;
    skos:prefLabel "Agricultura, ganadería, caza, silvicultura y pesca"@es ;
    skos:prefLabel "Agriculture, forestry and fishing"@en ;
    skos:notation "A" ;
    skos:closeMatch <https://unstats.un.org/unsd/classifications/Econ/isic#SectionA> ;
    skos:closeMatch <http://data.europa.eu/ux2/nace2/A> .

