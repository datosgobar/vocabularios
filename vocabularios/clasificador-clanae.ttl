#
# Fuente: INDEC — Disposición Nº 825/2010; Revisión 2017
# Base: CIIU Revisión 4 (ONU)
# Usos típicos: encuestas de empresas (ENGE, EMI, EIM, etc.)
# Estándares aplicados: SKOS, XKOS (DDI Alliance), DC Terms
# ================================================================

@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix xkos:   <http://rdf-vocabulary.ddialliance.org/xkos#> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf:   <http://xmlns.com/foaf/0.1/> .
@prefix clanae: <https://infra.datos.gob.ar/clasificador/clanae/> .

<https://infra.datos.gob.ar/clasificador/clanae>
    a owl:Ontology ;
    dct:title "ClaNAE 2010 — Clasificador Nacional de Actividades Económicas"@es ;
    dct:title "ClaNAE 2010 — National Classifier of Economic Activities"@en ;
    dct:description "Clasificador Nacional de Actividades Económicas 2010. Adaptación argentina de la CIIU Rev.4. Publicado y mantenido por la Dirección de Datos Abiertos."@es ;
    dct:creator <https://www.argentina.gob.ar/jefatura/innovacion-publica/datos-abiertos> ;
    dct:publisher <https://www.argentina.gob.ar/jefatura/innovacion-publica/datos-abiertos> ;
