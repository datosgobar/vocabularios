    skos:prefLabel "COICOP — Classification of Individual Consumption According to Purpose (UN)"@en ;
    skos:prefLabel "COICOP — Clasificación del Consumo Individual por Finalidades (ONU)"@es ;
    dct:publisher <https://unstats.un.org> ;
    rdfs:seeAlso <https://unstats.un.org/unsd/classifications/Family/Detail/1002> .

<https://www.ilo.org/public/english/bureau/stat/isco/>
    a skos:ConceptScheme ;
    skos:prefLabel "ISCO — International Standard Classification of Occupations (ILO)"@en ;
