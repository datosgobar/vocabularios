# =============================================================================
# Vocabulario de Provincias de la República Argentina
#
# ConceptScheme: Las 23 provincias y la Ciudad Autónoma de Buenos Aires (CABA).
# Sin relaciones jerárquicas a regiones en este archivo; el vínculo región-provincia
# está modelado solo en territorio-regiones.ttl (skos:narrower).
#
# Fuentes normativas:
#   SKOS Reference (W3C):     https://www.w3.org/TR/skos-reference/
#   GeoSPARQL 1.0 (OGC):      https://www.ogc.org/standard/geosparql/
#
# Fuentes de datos:
#   API Georef (datos.gob.ar): https://apis.datos.gob.ar/georef/api/
# =============================================================================

@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix dcat:    <http://www.w3.org/ns/dcat#> .
@prefix foaf:    <http://xmlns.com/foaf/0.1/> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix geo:     <http://www.opengis.net/ont/geosparql#> .
@prefix locn:    <http://www.w3.org/ns/locn#> .
@prefix wdt:     <http://www.wikidata.org/prop/direct/> .
@prefix wd:      <http://www.wikidata.org/entity/> .

# Vocabulario administrativo argentino — mismo espacio de nombres que territorio-regiones
@prefix aradm:   <https://infra.datos.gob.ar/vocabulario/territorio-argentina/> .

@base <https://infra.datos.gob.ar/vocabulario/territorio-argentina/> .


# =============================================================================
# CONCEPT SCHEME
# =============================================================================

<https://infra.datos.gob.ar/vocabulario/territorio-provincias>
    a skos:ConceptScheme ;
    dct:title "Provincias de la República Argentina"@es ;
    dct:title "Provinces of the Argentine Republic"@en ;
    dct:description "Vocabulario controlado de las 23 provincias y la Ciudad Autónoma de Buenos Aires. Las provincias se presentan como lista plana; su agrupamiento por región estadística está modelado en el vocabulario territorio-regiones."@es ;
    dct:description "Controlled vocabulary of the 23 provinces and the Autonomous City of Buenos Aires. Provinces are presented as a flat list; their grouping by statistical region is modelled in the territorio-regiones vocabulary."@en ;
    dct:creator [
        a foaf:Organization ;
        foaf:name "Jefatura de Gabinete de Ministros — Secretaría de Innovación, Ciencia y Tecnología - Subsecretaría de Tecnologías de Información y las Comunicaciones"@es
    ] ;
    dct:publisher [
        a foaf:Organization ;
        foaf:name "Dirección de Datos Abiertos"@es ;
        foaf:homepage <https://datos.gob.ar>
    ] ;
    dct:created "2026-05-15"^^xsd:date ;
    dct:modified "2026-06-17"^^xsd:date ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    dct:source <https://www.w3.org/TR/skos-reference/> ,
               <https://apis.datos.gob.ar/georef/> ;
    owl:versionInfo "1.0" ;
    skos:hasTopConcept <Provincia/Buenos-Aires> ;
    skos:hasTopConcept <Provincia/Catamarca> ;
    skos:hasTopConcept <Provincia/Chaco> ;
    skos:hasTopConcept <Provincia/Chubut> ;
    skos:hasTopConcept <Provincia/Cordoba> ;
    skos:hasTopConcept <Provincia/Corrientes> ;
    skos:hasTopConcept <Provincia/Entre-Rios> ;
    skos:hasTopConcept <Provincia/Formosa> ;
    skos:hasTopConcept <Provincia/Jujuy> ;
    skos:hasTopConcept <Provincia/La-Pampa> ;
    skos:hasTopConcept <Provincia/La-Rioja> ;
    skos:hasTopConcept <Provincia/Mendoza> ;
    skos:hasTopConcept <Provincia/Misiones> ;
    skos:hasTopConcept <Provincia/Neuquen> ;
    skos:hasTopConcept <Provincia/Rio-Negro> ;
    skos:hasTopConcept <Provincia/Salta> ;
    skos:hasTopConcept <Provincia/San-Juan> ;
    skos:hasTopConcept <Provincia/San-Luis> ;
    skos:hasTopConcept <Provincia/Santa-Cruz> ;
    skos:hasTopConcept <Provincia/Santa-Fe> ;
    skos:hasTopConcept <Provincia/Santiago-del-Estero> ;
    skos:hasTopConcept <Provincia/Tierra-del-Fuego> ;
    skos:hasTopConcept <Provincia/Tucuman> ;
    skos:hasTopConcept <CABA/Ciudad-Autonoma-de-Buenos-Aires> .


