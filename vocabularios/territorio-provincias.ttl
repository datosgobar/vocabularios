<Provincia/Buenos-Aires>
    a aradm:Provincia, skos:Concept ;
    skos:prefLabel "Provincia de Buenos Aires"@es ;
    skos:prefLabel "Buenos Aires Province"@en ;
    skos:altLabel "Buenos Aires"@es ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/territorio-provincias> ;
    skos:topConceptOf <https://infra.datos.gob.ar/vocabulario/territorio-provincias> ;
    aradm:pais <Pais/Argentina> ;
    owl:sameAs wd:Q44754 ;
    owl:sameAs <http://dbpedia.org/resource/Buenos_Aires_Province> ;
    skos:exactMatch <https://apis.datos.gob.ar/georef/api/provincias?nombre=Buenos%20Aires> ;
    dct:identifier "06" ;
    geo:hasGeometry [
        a geo:Geometry ;
        geo:asWKT "POLYGON((-63.4 -40.6, -56.3 -40.6, -56.3 -33.0, -63.4 -33.0, -63.4 -40.6))"^^geo:wktLiteral ;
