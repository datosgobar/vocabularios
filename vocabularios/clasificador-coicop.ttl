    skos:topConceptOf coicop:esquema-2019 ;
    # Nombre canónico (Metodología N°32 / cuadros de series):
    skos:prefLabel "Vivienda, agua, electricidad, gas y otros combustibles"@es ;
    skos:prefLabel "Housing, water, electricity, gas and other fuels"@en ;
    # ponderadores_ipc.xls tiene errata tipográfica (falta coma post "agua"):
    skos:hiddenLabel "Vivienda agua, electricidad y otros combustibles"@es ;
    skos:notation "04" ;
    skos:narrower coicop:grp04-1 , coicop:grp04-3 , coicop:grp04-4 , coicop:grp04-5 ;
    skos:closeMatch <https://unstats.un.org/unsd/classifications/Family/Detail/1002#04> .

