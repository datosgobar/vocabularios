    skos:topConceptOf coicop:esquema-2019 ;
    skos:prefLabel "Alimentos y bebidas no alcohólicas"@es ;
    skos:prefLabel "Food and non-alcoholic beverages"@en ;
    skos:notation "01" ;
    skos:narrower coicop:grp01-1 , coicop:grp01-2 ;
    skos:closeMatch <https://unstats.un.org/unsd/classifications/Family/Detail/1002#01> .

