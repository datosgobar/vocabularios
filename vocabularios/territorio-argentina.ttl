# =============================================================================
# Vocabulario de entidades territoriales de la República Argentina
#
# Fuentes normativas:
#   SKOS Reference (W3C):     https://www.w3.org/TR/skos-reference/
#   GeoSPARQL 1.0 (OGC):      https://www.ogc.org/standard/geosparql/
#
# Fuentes de datos:
#   API Georef (datos.gob.ar): https://apis.datos.gob.ar/georef/api/
# =============================================================================

@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix dcat:    <http://www.w3.org/ns/dcat#> .
@prefix foaf:    <http://xmlns.com/foaf/0.1/> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix geo:     <http://www.opengis.net/ont/geosparql#> .
@prefix locn:    <http://www.w3.org/ns/locn#> .
@prefix wdt:     <http://www.wikidata.org/prop/direct/> .
@prefix wd:      <http://www.wikidata.org/entity/> .

# Vocabulario administrativo argentino
@prefix aradm:   <https://infra.datos.gob.ar/vocabulario/territorio-argentina/> .

@base <https://infra.datos.gob.ar/vocabulario/territorio-argentina/> .


# =============================================================================
# ESQUEMA SKOS PRINCIPAL
# =============================================================================

<https://infra.datos.gob.ar/vocabulario/territorio-argentina>
    a skos:ConceptScheme ;
    dct:title "Territorios de la República Argentina"@es ;
    dct:title "Territories of the Argentine Republic"@en ;
    dct:description "Vocabulario controlado de entidades territoriales de la República Argentina: país, provincias, Ciudad Autónoma de Buenos Aires y regiones."@es ;
    dct:description "Controlled vocabulary of territorial entities of the Argentine Republic: country, provinces, Autonomous City of Buenos Aires, regions."@en ;
    dct:creator [
        a foaf:Organization ;
        foaf:name "Jefatura de Gabinete de Ministros — Secretaría de Innovación, Ciencia y Tecnología - Subsecretaría de Tecnologías de Información y las Comunicaciones"@es
    ] ;
    dct:publisher [
        a foaf:Organization ;
        foaf:name "Dirección de Datos Abiertos"@es ;
        foaf:homepage <https://datos.gob.ar>
    ] ;
    dct:created "2026-05-15"^^xsd:date ;
    dct:modified "2026-05-15"^^xsd:date ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    dct:source <https://www.w3.org/TR/skos-reference/> ,
               <https://apis.datos.gob.ar/georef/> ;
    owl:versionInfo "2.0" ;
    skos:hasTopConcept <Pais/Argentina> ;
    skos:hasTopConcept <Region/NOA> ;
    skos:hasTopConcept <Region/NEA> ;
    skos:hasTopConcept <Region/Cuyo> ;
    skos:hasTopConcept <Region/Pampeana> ;
    skos:hasTopConcept <Region/AMBA> ;
    skos:hasTopConcept <Region/Patagonia> .


# =============================================================================
# CLASES DEL VOCABULARIO ADMINISTRATIVO ARGENTINO
# =============================================================================

aradm:EntidadTerritorial
    a owl:Class ;
    rdfs:label "Entidad Territorial"@es ;
    rdfs:comment "Clase raíz para cualquier entidad territorial del vocabulario."@es .

aradm:Pais
    a owl:Class ;
    rdfs:label "País"@es ;
    rdfs:comment "Entidad de nivel nacional."@es ;
    rdfs:subClassOf aradm:EntidadTerritorial .

aradm:Region
    a owl:Class ;
    rdfs:label "Región"@es ;
    rdfs:label "Region"@en ;
    rdfs:comment "División supraprovincial sin estatus político-administrativo, utilizada para fines de análisis y planificación."@es ;
    rdfs:subClassOf aradm:EntidadTerritorial .

aradm:Provincia
    a owl:Class ;
    rdfs:label "Provincia"@es ;
    rdfs:comment "División administrativa de primer nivel de la República Argentina."@es ;
    rdfs:subClassOf aradm:EntidadTerritorial .

aradm:CABA
    a owl:Class ;
    rdfs:label "Ciudad Autónoma"@es ;
    rdfs:comment "Ciudad Autónoma de Buenos Aires, jurisdicción de estatus equivalente a provincia."@es ;
    rdfs:subClassOf aradm:EntidadTerritorial .

# Propiedad para vincular provincias/CABA con su región INDEC
aradm:region
    a owl:ObjectProperty ;
    rdfs:label "región"@es ;
    rdfs:comment "Relaciona una provincia o jurisdicción con la región a la que pertenece."@es ;
    rdfs:domain aradm:EntidadTerritorial ;
    rdfs:range aradm:Region .

# Propiedad para vincular provincias con su país
aradm:pais
    a owl:ObjectProperty ;
    rdfs:label "país"@es ;
    rdfs:domain aradm:EntidadTerritorial ;
    rdfs:range aradm:Pais .


# =============================================================================
# PAÍS: REPÚBLICA ARGENTINA
# =============================================================================

<Pais/Argentina>
    a aradm:Pais, skos:Concept ;
    skos:prefLabel "República Argentina"@es ;
    skos:prefLabel "Argentine Republic"@en ;
    skos:altLabel "Argentina"@es ;
    skos:altLabel "Argentina"@en ;
    skos:inScheme <vocabulario/territorio-argentina> ;
    skos:topConceptOf <vocabulario/territorio-argentina> ;
    skos:narrower <Region/NOA>, <Region/NEA>, <Region/Cuyo>,
                  <Region/Pampeana>, <Region/AMBA>, <Region/Patagonia> ;
    owl:sameAs wd:Q414 ;
    owl:sameAs <http://dbpedia.org/resource/Argentina> ;
    dct:identifier "AR" ;
    geo:hasGeometry [
        a geo:Geometry ;
        geo:asWKT "POLYGON((-75.5 -55.1, -53.6 -55.1, -53.6 -21.7, -75.5 -21.7, -75.5 -55.1))"^^geo:wktLiteral ;
        locn:geometry "{\"type\":\"Polygon\",\"coordinates\":[[[-75.5,-55.1],[-53.6,-55.1],[-53.6,-21.7],[-75.5,-21.7],[-75.5,-55.1]]]}"^^rdf:JSON
    ] .


