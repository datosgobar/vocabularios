# THEMES — AGRI
# =============================================================================

arth:lacteos
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Lácteos"@es ;
    skos:definition "Producción de leche y sus derivados industriales: volúmenes producidos, precios al productor y en industria y exportaciones del sector lácteo."@es ;
    skos:broader <SuperTheme/AGRI> .

arth:agricultura
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Agricultura"@es ;
    skos:definition "Superficies sembradas y cosechadas, volúmenes producidos, rendimientos y precios de los principales cultivos agrícolas anuales y perennes."@es ;
    skos:broader <SuperTheme/AGRI> .

arth:ganaderia
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Ganadería"@es ;
    skos:definition "Stock ganadero bovino, ovino, porcino y otras especies, producción de carne, faenamiento y precios en los distintos eslabones de la cadena."@es ;
    skos:broader <SuperTheme/AGRI> .

arth:pesca
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Pesca"@es ;
    skos:definition "Desembarcos de productos pesqueros marítimos y continentales, composición de las capturas por especie, esfuerzo pesquero y procesamiento industrial."@es ;
    skos:broader <SuperTheme/AGRI> .

arth:vitivinicultura
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Vitivinicultura"@es ;
    skos:definition "Producción de uvas, mostos y vinos, superficies plantadas por varietal, elaboración de vinos finos y comunes y exportaciones del sector."@es ;
    skos:broader <SuperTheme/AGRI> .

arth:apicultura
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Apicultura"@es ;
    skos:definition "Producción de miel y otros productos apícolas, stock de colmenas y exportaciones del sector."@es ;
    skos:broader <SuperTheme/AGRI> .

arth:horticultura
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Horticultura"@es ;
    skos:definition "Producción de hortalizas, legumbres y flores, superficies cultivadas, rendimientos y precios en mercados mayoristas."@es ;
    skos:broader <SuperTheme/AGRI> .

arth:agroindustria
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Agroindustria"@es ;
    skos:definition "Procesamiento industrial de materias primas de origen agropecuario: oleaginosas, cereales, azúcar, tabaco y otras cadenas agroindustriales."@es ;
    skos:broader <SuperTheme/AGRI> .


