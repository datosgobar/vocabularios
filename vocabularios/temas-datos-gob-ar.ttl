# THEMES — HEAL
# =============================================================================

arth:medicamentos
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Medicamentos"@es ;
