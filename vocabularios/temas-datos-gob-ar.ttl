arth:adicciones-consumo-problematico
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Adicciones y consumo problemático"@es ;
    skos:definition "Prevalencia del consumo de sustancias psicoactivas, tendencias de consumo y acceso a tratamientos especializados."@es ;
    skos:broader <SuperTheme/HEAL> .


# =============================================================================
# THEMES — EDUC
# =============================================================================

arth:educacion
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Educación"@es ;
    skos:definition "Matrícula, asistencia, trayectorias y resultados del sistema educativo formal en todos sus niveles: inicial, primario, secundario, superior y universitario. Incluye indicadores de repitencia, abandono, egreso y establecimientos educativos."@es ;
    skos:broader <SuperTheme/EDUC> .

arth:evaluacion-educativa
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Evaluación educativa"@es ;
    skos:definition "Desempeño de los estudiantes en pruebas nacionales e internacionales de aprendizaje, utilizados para medir la calidad del sistema educativo."@es ;
    skos:broader <SuperTheme/EDUC> .

arth:cultura
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Cultura"@es ;
    skos:definition "Producción, distribución y consumo cultural: libros, cine, música, teatro, museos y otras industrias culturales, incluyendo el aporte del sector al producto bruto."@es ;
    skos:broader <SuperTheme/EDUC> .

arth:deportes
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Deportes"@es ;
    skos:definition "Práctica deportiva de la población, infraestructura deportiva disponible y resultados de competencias deportivas nacionales e internacionales."@es ;
    skos:broader <SuperTheme/EDUC> .


# =============================================================================
# THEMES — TECH
# =============================================================================

arth:acceso-uso-tics
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Acceso y uso de TIC"@es ;
    skos:definition "Acceso y uso de dispositivos y servicios de telecomunicaciones e información en los hogares y las empresas: penetración de telefonía fija y móvil, internet, computadoras y otros dispositivos digitales."@es ;
    skos:broader <SuperTheme/TECH> .

arth:ciencia-tecnologia
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Ciencia e investigación"@es ;
    skos:altLabel "Ciencia y tecnología"@es ;
    skos:definition "Esfuerzo en investigación y desarrollo (I+D): gasto en I+D como porcentaje del PIB, cantidad de investigadores, publicaciones científicas y patentes registradas."@es ;
    skos:broader <SuperTheme/TECH> .

arth:infraestructura-digital
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Infraestructura digital"@es ;
    skos:definition "Cobertura y calidad de las redes de telecomunicaciones: fibra óptica, redes móviles 4G y 5G y conectividad en zonas rurales y periurbanas."@es ;
    skos:broader <SuperTheme/TECH> .


# =============================================================================
# THEMES — TERRI
# =============================================================================

arth:division-territorial
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "División territorial"@es ;
    skos:definition "Organización político-administrativa del territorio: provincias, departamentos, municipios, localidades y otras unidades de análisis geográfico."@es ;
    skos:broader <SuperTheme/TERRI> .

arth:ecosistemas
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Ecosistemas"@es ;
    skos:definition "Cobertura y estado de los distintos biomas y ecosistemas del territorio nacional: bosques nativos, humedales, pastizales y zonas áridas."@es ;
    skos:broader <SuperTheme/TERRI> .

arth:geologia
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Geología"@es ;
    skos:definition "Estructura geológica del territorio, los recursos minerales y la sismicidad, relevantes para la planificación territorial y la gestión del riesgo."@es ;
    skos:broader <SuperTheme/TERRI> .

arth:hidrografia
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Hidrografía"@es ;
    skos:definition "Recursos hídricos superficiales y subterráneos: caudales, cuencas hidrográficas, acuíferos y su disponibilidad para distintos usos."@es ;
    skos:broader <SuperTheme/TERRI> .


# =============================================================================
# THEMES — INTR
# =============================================================================

arth:diplomacia
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Diplomacia"@es ;
    skos:definition "Red de representaciones diplomáticas y consulares de Argentina en el exterior, acuerdos y tratados internacionales vigentes y actividad de organismos multilaterales."@es ;
    skos:broader <SuperTheme/INTR> .


# =============================================================================
# THEMES — DEFE (extensión local)
# =============================================================================

arth:fuerzas-armadas
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Fuerzas Armadas"@es ;
    skos:definition "Dotación de personal militar y civil en las distintas ramas de las Fuerzas Armadas, el presupuesto de defensa y las actividades operacionales y de entrenamiento."@es ;
    skos:broader arth:DEFE .

arth:soberania-proteccion-vigilancia
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Soberanía, protección y vigilancia"@es ;
    skos:definition "Actividades de patrullaje y control territorial, la defensa de las fronteras nacionales y las operaciones de protección de los recursos soberanos del país."@es ;
    skos:broader arth:DEFE .

arth:riesgos-desastres
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Riesgos y desastres"@es ;
    skos:definition "Datos sobre la gestión del riesgo de desastres naturales y antrópicos, incluyendo alertas tempranas, planes de emergencia y registro de eventos."@es ;
    skos:broader arth:DEFE .

