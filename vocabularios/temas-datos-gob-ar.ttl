arth:establecimientos-salud
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Establecimientos de salud"@es ;
    skos:definition "Cantidad, categoría, distribución territorial y dotación de recursos físicos (camas, quirófanos, equipamiento) de los establecimientos del sistema de salud público y privado."@es ;
    skos:broader <SuperTheme/HEAL> .

arth:especialidades-tratamientos
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Especialidades y tratamientos médicos"@es ;
