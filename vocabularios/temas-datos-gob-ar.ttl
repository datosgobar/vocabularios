# THEMES — JUST
# =============================================================================

arth:estadisticas-criminales
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Estadísticas criminales"@es ;
    skos:definition "Incidencia, distribución territorial y evolución de los delitos registrados, incluyendo tasas de victimización, tipos de delitos y características de los hechos denunciados."@es ;
    skos:broader <SuperTheme/JUST> .

arth:canales-denuncia
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Canales y líneas de denuncia"@es ;
    skos:definition "Uso de los mecanismos institucionales de denuncia ciudadana (líneas telefónicas, plataformas digitales) y los resultados de su gestión."@es ;
    skos:broader <SuperTheme/JUST> .

arth:tramites-registro-automotor
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Trámites y registro automotor"@es ;
    skos:definition "Transferencias, radicaciones e inscripciones de vehículos en el Registro Nacional de la Propiedad Automotor, incluyendo patentamientos de vehículos nuevos y usados."@es ;
    skos:broader <SuperTheme/JUST> .

arth:servicio-penitenciario
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Servicio penitenciario"@es ;
    skos:definition "Población privada de libertad en establecimientos penitenciarios: cantidad de internos, características sociodemográficas, tipos de delitos y condiciones de detención."@es ;
    skos:broader <SuperTheme/JUST> .

arth:centros-tribunales-justicia
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Centros y tribunales de justicia"@es ;
    skos:definition "Cantidad, distribución y funcionamiento de los órganos jurisdiccionales y auxiliares del Poder Judicial en los distintos fueros y jurisdicciones."@es ;
    skos:broader <SuperTheme/JUST> .

arth:administracion-justicia
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Administración de la justicia"@es ;
    skos:definition "Carga de trabajo del sistema judicial: causas iniciadas, resueltas y pendientes, tiempos de resolución y resultados de los procesos judiciales por tipo de fuero."@es ;
    skos:broader <SuperTheme/JUST> .

arth:derechos-humanos
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Derechos humanos"@es ;
    skos:definition "Vulneraciones y violaciones a los derechos humanos fundamentales, los mecanismos de reparación histórica y el acceso a la identidad y la integridad personal."@es ;
    skos:broader <SuperTheme/JUST> .

arth:violencia-genero
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Violencia de género"@es ;
    skos:definition "Datos sobre la incidencia, tipos y características de la violencia ejercida por razones de género, incluyendo femicidios, denuncias y medidas de protección."@es ;
    skos:broader <SuperTheme/JUST> ;
    skos:related arth:genero-diversidad .

arth:elecciones
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Elecciones"@es ;
    skos:definition "Datos electorales: padrón de electores, participación ciudadana, resultados de elecciones nacionales, provinciales y municipales y distribución de bancas y cargos."@es ;
    skos:broader <SuperTheme/JUST> .


