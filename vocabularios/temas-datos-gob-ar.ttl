arth:estadisticas-vitales
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Estadísticas vitales"@es ;
    skos:definition "Registros de nacimientos, defunciones, causas de muerte, matrimonios y divorcios."@es ;
    skos:broader <SuperTheme/HEAL> .

