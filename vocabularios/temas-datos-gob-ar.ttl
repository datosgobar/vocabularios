# =============================================================================
# Vocabulario de Temas del Catálogo de Datos Abiertos de la República Argentina
#
# SuperThemes: URIs canónicas en infra.datos.gob.ar (SuperTheme/{CODIGO}).
#   Alineados al vocabulario MDR de la UE (DCAT-AP) mediante skos:exactMatch.
#   URI base local:  https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar/SuperTheme/
#   URI base EU ref: http://publications.europa.eu/resource/authority/data-theme/
#   DEFE es una extensión local sin equivalente en el vocabulario europeo.
#
# Themes: conceptos propios de datos.gob.ar, relacionados jerárquicamente
#   con los superThemes mediante skos:broader / skos:narrower.
#
# Fuentes normativas:
#   SKOS Reference (W3C):   https://www.w3.org/TR/skos-reference/
#   DCAT-AP 3.0 (W3C/EU):   https://www.w3.org/TR/vocab-dcat-3/
#   MDR Data Theme (EU):    http://publications.europa.eu/resource/authority/data-theme
# =============================================================================

@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix dcat:   <http://www.w3.org/ns/dcat#> .
@prefix foaf:   <http://xmlns.com/foaf/0.1/> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .

# Prefijo del vocabulario europeo de referencia (MDR) — usado solo en skos:exactMatch
# @prefix eu-theme: <http://publications.europa.eu/resource/authority/data-theme/> .

# Prefijo local
@prefix arth:   <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar/> .

@base <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar/> .


# =============================================================================
# CONCEPT SCHEME
# =============================================================================

<https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar>
    a skos:ConceptScheme ;
    dct:title "Temas del Catálogo de Datos Abiertos de la República Argentina"@es ;
    dct:title "Themes of the Open Data Catalogue of the Argentine Republic"@en ;
    dct:description "Vocabulario controlado de temas y superTemas utilizado para la clasificación de conjuntos de datos en datos.gob.ar. Los superTemas adoptan el vocabulario MDR de la Unión Europea (DCAT-AP); los temas son conceptos propios del catálogo argentino."@es ;
    dct:description "Controlled vocabulary of themes and super-themes used to classify datasets in datos.gob.ar. Super-themes adopt the EU MDR vocabulary (DCAT-AP); themes are concepts specific to the Argentine catalogue."@en ;
    dct:creator [
        a foaf:Organization ;
        foaf:name "Subsecretaría de Tecnologías de la Información — Ministerio de Economía de la Nación"@es
    ] ;
    dct:publisher [
        a foaf:Organization ;
        foaf:name "datos.gob.ar"@es ;
        foaf:homepage <https://datos.gob.ar>
    ] ;
    dct:created "2025-05-15"^^xsd:date ;
    dct:modified "2025-05-15"^^xsd:date ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    dct:source <http://publications.europa.eu/resource/authority/data-theme> ;
    owl:versionInfo "1.0" ;
    # SuperThemes con URIs locales; alineados al MDR europeo mediante skos:exactMatch
    skos:hasTopConcept <SuperTheme/SOCI> ;
    skos:hasTopConcept <SuperTheme/ENVI> ;
    skos:hasTopConcept <SuperTheme/ECON> ;
    skos:hasTopConcept <SuperTheme/TRAN> ;
    skos:hasTopConcept <SuperTheme/ENER> ;
    skos:hasTopConcept <SuperTheme/JUST> ;
    skos:hasTopConcept <SuperTheme/GOVE> ;
    skos:hasTopConcept <SuperTheme/AGRI> ;
    skos:hasTopConcept <SuperTheme/HEAL> ;
    skos:hasTopConcept <SuperTheme/EDUC> ;
    skos:hasTopConcept <SuperTheme/TECH> ;
    skos:hasTopConcept <SuperTheme/TERRI> ;
    skos:hasTopConcept <SuperTheme/INTR> ;
    skos:hasTopConcept arth:DEFE .


# =============================================================================
# SUPERTHEMES — URIs locales, alineados al vocabulario MDR de la UE
# Cada superTheme tiene su URI canónica en infra.datos.gob.ar y referencia
# al concepto equivalente del MDR europeo mediante skos:exactMatch.
# =============================================================================

<SuperTheme/SOCI>
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:topConceptOf <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Población y sociedad"@es ;
    skos:prefLabel "Population and society"@en ;
    skos:definition "Políticas destinadas a la población y asuntos vinculados con la estructura demográfica del país, composición y dinámica de la población, condiciones de vida y características culturales y de identidad."@es ;
    skos:notation "SOCI" ;
    skos:exactMatch <http://publications.europa.eu/resource/authority/data-theme/SOCI> ;
    skos:narrower arth:genero-diversidad ,
                  arth:discapacidad ,
                  arth:culto-religion ,
                  arth:demografia-poblacion ,
                  arth:pueblos-originarios ,
                  arth:migracion-naturalizacion ,
                  arth:condiciones-habitacionales ,
                  arth:pobreza-desigualdad .

<SuperTheme/ENVI>
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:topConceptOf <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Medio ambiente"@es ;
    skos:prefLabel "Environment"@en ;
    skos:definition "Estado y evolución de los recursos naturales, los seres vivos y su interacción con el contexto, la calidad del ambiente y los fenómenos meteorológicos."@es ;
    skos:notation "ENVI" ;
    skos:exactMatch <http://publications.europa.eu/resource/authority/data-theme/ENVI> ;
    skos:narrower arth:contaminacion-calidad ,
                  arth:residuos-basurales ,
                  arth:sustentabilidad ,
                  arth:biodiversidad-recursos-naturales ,
                  arth:areas-protegidas ,
                  arth:suelo-degradacion-tierras ,
                  arth:meteorologia .

<SuperTheme/ECON>
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:topConceptOf <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Economía y finanzas"@es ;
    skos:prefLabel "Economy and finance"@en ;
    skos:definition "Gestión económica, asignación de recursos y control presupuestario, así como datos que describen la actividad productiva, el nivel de precios, el comercio, el mercado de trabajo, las finanzas públicas y el sector externo de la economía argentina."@es ;
    skos:notation "ECON" ;
    skos:exactMatch <http://publications.europa.eu/resource/authority/data-theme/ECON> ;
    skos:narrower arth:infraestructura-obras-publicas ,
                  arth:prestaciones-sociales ,
                  arth:presupuesto ,
                  arth:cuentas-nacionales ,
                  arth:precios ,
                  arth:sector-primario ,
                  arth:sector-secundario ,
                  arth:sector-terciario ,
                  arth:sector-cuarto ,
                  arth:mercado-laboral-ingresos ,
                  arth:deuda-publica ,
                  arth:mercado-financiero .

<SuperTheme/TRAN>
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:topConceptOf <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Transporte"@es ;
    skos:prefLabel "Transport"@en ;
    skos:definition "Asuntos vinculados con la demanda, oferta y calidad de los distintos modos de transporte de personas y cargas."@es ;
    skos:notation "TRAN" ;
    skos:exactMatch <http://publications.europa.eu/resource/authority/data-theme/TRAN> ;
    skos:narrower arth:transporte-publico-urbano ,
                  arth:aviacion-aeropuertos ,
                  arth:transporte-maritimo-fluvial-puertos ,
                  arth:ferrocarriles .

<SuperTheme/ENER>
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:topConceptOf <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Energía"@es ;
    skos:prefLabel "Energy"@en ;
    skos:definition "Asuntos vinculados con la generación, distribución y conservación de la energía en sus distintas formas y fuentes."@es ;
    skos:notation "ENER" ;
    skos:exactMatch <http://publications.europa.eu/resource/authority/data-theme/ENER> ;
    skos:narrower arth:hidrocarburos-combustibles-fosiles ,
                  arth:energia-electrica ,
                  arth:energia-hidroelectrica ,
                  arth:energias-renovables .

<SuperTheme/JUST>
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:topConceptOf <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Justicia y seguridad"@es ;
    skos:prefLabel "Justice, legal system and public safety"@en ;
    skos:definition "Asuntos vinculados con el sistema judicial, derechos humanos, delitos e instituciones de seguridad y procesos electorales."@es ;
    skos:notation "JUST" ;
    skos:exactMatch <http://publications.europa.eu/resource/authority/data-theme/JUST> ;
    skos:narrower arth:estadisticas-criminales ,
                  arth:canales-denuncia ,
                  arth:tramites-registro-automotor ,
                  arth:servicio-penitenciario ,
                  arth:centros-tribunales-justicia ,
                  arth:administracion-justicia ,
                  arth:derechos-humanos ,
                  arth:violencia-genero ,
                  arth:elecciones .

<SuperTheme/GOVE>
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:topConceptOf <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Gobierno y sector público"@es ;
    skos:prefLabel "Government and public sector"@en ;
    skos:definition "Asuntos vinculados con la estructura del Estado y la gobernanza: funcionamiento de las instituciones públicas, transparencia, rendición de cuentas y patrimonio del Estado."@es ;
    skos:notation "GOVE" ;
    skos:exactMatch <http://publications.europa.eu/resource/authority/data-theme/GOVE> ;
    skos:narrower arth:compras-contrataciones ,
                  arth:rendicion-cuentas ,
                  arth:personal-estado ,
                  arth:inmuebles-estado ,
                  arth:gobierno-abierto .

<SuperTheme/AGRI>
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:topConceptOf <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Agroganadería, pesca y forestación"@es ;
    skos:prefLabel "Agriculture, fisheries, forestry and food"@en ;
    skos:definition "Procesos destinados a la explotación, manejo y aprovechamiento de los recursos del suelo, el agua y el aire para la producción de alimentos, fibras y otros productos de origen orgánico. Comprende datos sobre la producción, precios y estructura del sector agropecuario, forestal y pesquero."@es ;
    skos:notation "AGRI" ;
    skos:exactMatch <http://publications.europa.eu/resource/authority/data-theme/AGRI> ;
    skos:narrower arth:lacteos ,
                  arth:agricultura ,
                  arth:ganaderia ,
                  arth:pesca ,
                  arth:vitivinicultura ,
                  arth:apicultura ,
                  arth:horticultura ,
                  arth:agroindustria .

<SuperTheme/HEAL>
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:topConceptOf <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Salud"@es ;
    skos:prefLabel "Health"@en ;
    skos:definition "Asuntos vinculados con el consumo, la vigilancia y el estado de la salud de la población, los recursos del sistema sanitario y los eventos vitales."@es ;
    skos:notation "HEAL" ;
    skos:exactMatch <http://publications.europa.eu/resource/authority/data-theme/HEAL> ;
    skos:narrower arth:medicamentos ,
                  arth:vigilancia-epidemiologica ,
                  arth:vacunacion ,
                  arth:estadisticas-vitales ,
                  arth:recursos-humanos-salud ,
                  arth:salud-sexual-reproductiva ,
                  arth:obras-sociales-prepagas ,
                  arth:establecimientos-salud ,
                  arth:especialidades-tratamientos ,
                  arth:trasplantes-donaciones ,
                  arth:adicciones-consumo-problematico .

<SuperTheme/EDUC>
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:topConceptOf <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Educación, cultura y deportes"@es ;
    skos:prefLabel "Education, culture and sport"@en ;
    skos:definition "Datos sobre el sistema educativo, el acceso a la cultura, el deporte y las políticas en estos ámbitos."@es ;
    skos:notation "EDUC" ;
    skos:exactMatch <http://publications.europa.eu/resource/authority/data-theme/EDUC> ;
    skos:narrower arth:educacion ,
                  arth:evaluacion-educativa ,
                  arth:cultura ,
                  arth:deportes .

<SuperTheme/TECH>
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:topConceptOf <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Ciencia y tecnología"@es ;
    skos:prefLabel "Science and technology"@en ;
    skos:definition "Acceso y uso de tecnologías de la información y la comunicación (TIC), la ciencia, la investigación y la infraestructura digital."@es ;
    skos:notation "TECH" ;
    skos:exactMatch <http://publications.europa.eu/resource/authority/data-theme/TECH> ;
    skos:narrower arth:acceso-uso-tics ,
                  arth:ciencia-tecnologia ,
                  arth:infraestructura-digital .

# TERRI: código presente en el MDR europeo; se alinea con skos:exactMatch.
<SuperTheme/TERRI>
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:topConceptOf <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Territorio"@es ;
    skos:prefLabel "Territory and geography"@en ;
    skos:definition "Asuntos vinculados con la geografía y el territorio: división político-administrativa, ecosistemas, geología y recursos hídricos del país."@es ;
    skos:notation "TERRI" ;
    skos:exactMatch <http://publications.europa.eu/resource/authority/data-theme/TERRI> ;
    skos:narrower arth:division-territorial ,
                  arth:ecosistemas ,
                  arth:geologia ,
                  arth:hidrografia .

<SuperTheme/INTR>
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:topConceptOf <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Asuntos internacionales"@es ;
    skos:prefLabel "International issues"@en ;
    skos:definition "Aspectos vinculados con la política internacional de Argentina, las relaciones diplomáticas y la inserción del país en el sistema internacional."@es ;
    skos:notation "INTR" ;
    skos:exactMatch <http://publications.europa.eu/resource/authority/data-theme/INTR> ;
    skos:narrower arth:diplomacia .

# DEFE: extensión local sin equivalente en el vocabulario MDR de la UE
arth:DEFE
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:topConceptOf <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Defensa"@es ;
    skos:prefLabel "Defence"@en ;
    skos:definition "Asuntos vinculados con el personal y la conducción de las Fuerzas Armadas, la defensa territorial, la soberanía y la autodeterminación de la Nación."@es ;
    skos:notation "DEFE" ;
    skos:narrower arth:fuerzas-armadas ,
                  arth:soberania-proteccion-vigilancia ,
                  arth:riesgos-desastres .


# =============================================================================
# THEMES — SOCI
# =============================================================================

arth:genero-diversidad
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Género y diversidad sexual"@es ;
    skos:definition "Información sobre la composición de la población según género, identidad de género y orientación sexual. Incluye datos sobre brechas de género en el mercado laboral, acceso a derechos, violencia por razones de género e indicadores de diversidad e inclusión."@es ;
    skos:broader <SuperTheme/SOCI> .

arth:discapacidad
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Discapacidad"@es ;
    skos:definition "Datos sobre la prevalencia, tipos y grados de discapacidad en la población, así como el acceso de las personas con discapacidad a servicios."@es ;
    skos:broader <SuperTheme/SOCI> .

arth:culto-religion
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Culto y religión"@es ;
    skos:definition "Datos sobre la composición religiosa de la población, la distribución de cultos reconocidos y su presencia territorial en el país."@es ;
    skos:broader <SuperTheme/SOCI> .

arth:demografia-poblacion
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Demografía y población"@es ;
    skos:definition "Estructura, distribución y dinámica de la población: tamaño, composición por edad, sexo, proyecciones demográficas y censos de población."@es ;
    skos:broader <SuperTheme/SOCI> .

arth:pueblos-originarios
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Pueblos originarios"@es ;
    skos:definition "Composición, distribución territorial, condiciones de vida y características socioculturales de los pueblos originarios que habitan el territorio nacional."@es ;
    skos:broader <SuperTheme/SOCI> .

arth:migracion-naturalizacion
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Migración y naturalización"@es ;
    skos:definition "Flujos migratorios internacionales e internos, composición de la población extranjera residente y procesos de naturalización."@es ;
    skos:broader <SuperTheme/SOCI> .

arth:condiciones-habitacionales
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Condiciones habitacionales"@es ;
    skos:definition "Acceso a la vivienda, sus características constructivas y de equipamiento, la situación de tenencia y las condiciones del hábitat circundante. Incluye indicadores de calidad de la vivienda y del entorno."@es ;
    skos:broader <SuperTheme/SOCI> .

arth:pobreza-desigualdad
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Pobreza y desigualdad"@es ;
    skos:definition "Indicadores sobre la incidencia de la pobreza y la indigencia en hogares y personas, la distribución del ingreso, las brechas socioeconómicas y los recursos mínimos necesarios para la subsistencia."@es ;
    skos:broader <SuperTheme/SOCI> .


# =============================================================================
# THEMES — ENVI
# =============================================================================

arth:contaminacion-calidad
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Contaminación y calidad ambiental"@es ;
    skos:definition "Calidad del aire, el agua y el suelo, niveles de emisiones contaminantes y su evolución temporal. Abarca mediciones de sustancias nocivas en el ambiente y sus impactos sobre la salud y los ecosistemas."@es ;
    skos:broader <SuperTheme/ENVI> .

arth:residuos-basurales
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Residuos y basurales"@es ;
    skos:definition "Generación, composición, gestión y disposición final de residuos sólidos urbanos e industriales, así como la presencia de basurales a cielo abierto."@es ;
    skos:broader <SuperTheme/ENVI> .

arth:sustentabilidad
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Sustentabilidad"@es ;
    skos:definition "Uso eficiente de los recursos naturales, la huella ambiental de las actividades productivas y el avance hacia modelos de desarrollo sostenible."@es ;
    skos:broader <SuperTheme/ENVI> .

arth:biodiversidad-recursos-naturales
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Biodiversidad y recursos naturales"@es ;
    skos:definition "Diversidad de especies, ecosistemas y recursos genéticos en el territorio nacional, incluyendo el estado de conservación de la fauna y flora."@es ;
    skos:broader <SuperTheme/ENVI> .

arth:areas-protegidas
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Áreas protegidas"@es ;
    skos:definition "Extensión, categorías, distribución y gestión de las áreas naturales protegidas en el territorio nacional y sus zonas de amortiguamiento."@es ;
    skos:broader <SuperTheme/ENVI> .

arth:suelo-degradacion-tierras
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Suelo y degradación de tierras"@es ;
    skos:definition "Uso del suelo, procesos de erosión, desertificación y degradación de tierras productivas, así como cobertura vegetal."@es ;
    skos:broader <SuperTheme/ENVI> .

arth:meteorologia
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Meteorología"@es ;
    skos:definition "Variables climáticas y meteorológicas: temperatura, precipitaciones, humedad, viento y fenómenos extremos, con sus distribuciones temporales y espaciales."@es ;
    skos:broader <SuperTheme/ENVI> .


# =============================================================================
# THEMES — ECON
# =============================================================================

arth:infraestructura-obras-publicas
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Infraestructura y obras públicas"@es ;
    skos:definition "Inversión del Estado en infraestructura y obras de capital: edificios públicos, vialidad, señalización, redes sanitarias y energéticas, entre otros. Registra la evolución del gasto en obra pública por nivel de gobierno y tipo de proyecto."@es ;
    skos:broader <SuperTheme/ECON> .

arth:prestaciones-sociales
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Prestaciones sociales"@es ;
    skos:definition "Erogaciones del Estado destinadas a prestaciones de seguridad social, programas de transferencias de ingresos, subsidios y servicios sociales provistos por el sector público."@es ;
    skos:broader <SuperTheme/ECON> .

arth:presupuesto
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Presupuesto"@es ;
    skos:definition "Programación, ejecución y resultado de las finanzas del sector público: ingresos tributarios y no tributarios, gastos corrientes y de capital, resultado fiscal y su financiamiento."@es ;
    skos:broader <SuperTheme/ECON> .

arth:cuentas-nacionales
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Cuentas nacionales"@es ;
    skos:definition "Sistema integrado de estadísticas macroeconómicas que describe el proceso de generación, distribución y utilización del ingreso en la economía nacional. Comprende las cuentas del sistema de cuentas nacionales (SCN) en sus distintas presentaciones temporales y sectoriales."@es ;
    skos:broader <SuperTheme/ECON> .

arth:precios
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Precios"@es ;
    skos:definition "Índices que miden la evolución de los precios en los distintos eslabones de la cadena económica: consumidor, productor y comercio exterior."@es ;
    skos:broader <SuperTheme/ECON> .

arth:sector-primario
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Sector primario"@es ;
    skos:definition "Actividad económica basada en la extracción y producción de recursos naturales: agricultura, minería, pesca y sus indicadores de producción y desempeño."@es ;
    skos:broader <SuperTheme/ECON> ;
    skos:related arth:agricultura ;
    skos:related arth:pesca .

arth:sector-secundario
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Sector secundario"@es ;
    skos:definition "Actividad industrial y de la construcción: producción manufacturera, construcción, energía y sus indicadores de capacidad, empleo y precios."@es ;
    skos:broader <SuperTheme/ECON> .

arth:sector-terciario
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Sector terciario"@es ;
    skos:definition "Comercio y turismo: desempeño del comercio minorista y mayorista, evolución de ventas y precios, movimiento de viajeros, ocupación hotelera y gasto turístico."@es ;
    skos:broader <SuperTheme/ECON> .

arth:sector-cuarto
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Comercio exterior"@es ;
    skos:altLabel "Sector cuarto"@es ;
    skos:definition "Flujos de bienes y servicios entre Argentina y el resto del mundo: valores, cantidades, precios, términos del intercambio y composición por producto y destino u origen."@es ;
    skos:broader <SuperTheme/ECON> .

arth:mercado-laboral-ingresos
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Mercado laboral e ingresos"@es ;
    skos:definition "Participación de la población en el mercado de trabajo, condiciones de ocupación y desocupación, evolución de los salarios y distribución del ingreso de los hogares."@es ;
    skos:broader <SuperTheme/ECON> .

arth:deuda-publica
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Deuda pública"@es ;
    skos:definition "Stock, composición, plazo y evolución de la deuda del sector público nacional, provincial y municipal, así como servicios de deuda y financiamiento."@es ;
    skos:broader <SuperTheme/ECON> .

arth:mercado-financiero
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Mercado financiero"@es ;
    skos:definition "Flujos de capital, inversiones extranjeras directas y de cartera, posición financiera de Argentina frente al resto del mundo y tipo de cambio."@es ;
    skos:broader <SuperTheme/ECON> .


# =============================================================================
# THEMES — TRAN
# =============================================================================

arth:transporte-publico-urbano
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Transporte público urbano"@es ;
    skos:definition "Uso y oferta de servicios de transporte colectivo en áreas urbanas: colectivos, subterráneos y otros medios de transporte masivo, incluyendo cantidad de pasajeros, frecuencias y tarifas."@es ;
    skos:broader <SuperTheme/TRAN> .

arth:aviacion-aeropuertos
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Aviación y aeropuertos"@es ;
    skos:definition "Tráfico aéreo de pasajeros y cargas, movimientos de aeronaves, conectividad de los aeropuertos y desempeño de las aerolíneas que operan en el país."@es ;
    skos:broader <SuperTheme/TRAN> .

arth:transporte-maritimo-fluvial-puertos
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Transporte marítimo, fluvial y puertos"@es ;
    skos:definition "Movimiento de buques, cargas y pasajeros en puertos y vías navegables, incluyendo datos de cabotaje e hidrovías."@es ;
    skos:broader <SuperTheme/TRAN> .

arth:ferrocarriles
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Ferrocarriles"@es ;
    skos:definition "Transporte ferroviario de pasajeros y cargas: kilómetros recorridos, frecuencias, demanda y oferta de los servicios de tren urbano e interurbano."@es ;
    skos:broader <SuperTheme/TRAN> .


# =============================================================================
# THEMES — ENER
# =============================================================================

arth:hidrocarburos-combustibles-fosiles
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Hidrocarburos y combustibles fósiles"@es ;
    skos:definition "Producción, reservas, refinación, transporte y consumo de petróleo, gas natural y sus derivados, incluyendo la evolución de los precios en el mercado doméstico e internacional."@es ;
    skos:broader <SuperTheme/ENER> .

arth:energia-electrica
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Energía eléctrica"@es ;
    skos:definition "Generación, transmisión, distribución y consumo de energía eléctrica, así como la capacidad instalada del parque generador y la calidad del suministro."@es ;
    skos:broader <SuperTheme/ENER> .

arth:energia-hidroelectrica
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Energía hidroeléctrica"@es ;
    skos:definition "Producción de energía eléctrica a partir de recursos hídricos, capacidad instalada en centrales hidroeléctricas y aporte de esta fuente a la matriz energética."@es ;
    skos:broader <SuperTheme/ENER> ;
    skos:related arth:energia-electrica .

arth:energias-renovables
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Energías renovables"@es ;
    skos:definition "Generación de energía a partir de fuentes solar, eólica, geotérmica y otras renovables, incluyendo la evolución de la capacidad instalada y su participación en la matriz energética. Producción, mezcla y consumo de biocombustibles."@es ;
    skos:broader <SuperTheme/ENER> .


