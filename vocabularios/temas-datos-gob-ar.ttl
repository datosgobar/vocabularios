# THEMES — GOVE
# =============================================================================

arth:compras-contrataciones
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Compras y contrataciones"@es ;
    skos:definition "Insumos, bienes y servicios adquiridos por los distintos organismos públicos a través de los mecanismos de contratación del Estado."@es ;
    skos:broader <SuperTheme/GOVE> .

arth:rendicion-cuentas
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Rendición de cuentas"@es ;
    skos:definition "Mecanismos de control y fiscalización del sector público: auditorías, informes de ejecución presupuestaria y otros instrumentos de transparencia en la gestión gubernamental."@es ;
    skos:broader <SuperTheme/GOVE> .

arth:personal-estado
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Personal del Estado"@es ;
    skos:definition "Dotación de empleados públicos en la Administración Pública Nacional, las provincias y los municipios, incluyendo su composición por categoría, escalafón y remuneraciones."@es ;
    skos:broader <SuperTheme/GOVE> .

arth:inmuebles-estado
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Inmuebles del Estado"@es ;
    skos:definition "Patrimonio inmobiliario del Estado: cantidad, localización, destino y estado de los inmuebles de propiedad del sector público nacional, provincial y municipal."@es ;
    skos:broader <SuperTheme/GOVE> .

arth:gobierno-abierto
    a skos:Concept ;
    skos:inScheme <https://infra.datos.gob.ar/vocabulario/temas-datos-gob-ar> ;
    skos:prefLabel "Gobierno abierto"@es ;
    skos:definition "Iniciativas de apertura y publicación de datos gubernamentales, planes de acción de gobierno abierto y estándares de transparencia adoptados por el Estado."@es ;
    skos:broader <SuperTheme/GOVE> .


