# 2. CAES
#    Clasificación de Actividades Económicas para Encuestas
#    Sociodemográficas (versión 2018)
#    Fuente: INDEC
#    Usos típicos: EPH, ENGHO, EPS y otras encuestas a hogares.
#    Propósito distinto al ClaNAE: simplifica la clasificación
#    para que pueda ser aplicada por encuestadores en el campo.
# ================================================================

caes:esquema
    a skos:ConceptScheme ;
    dct:title "CAES — Clasificación de Actividades Económicas para Encuestas Sociodemográficas"@es ;
    skos:prefLabel "CAES — Clasificación de Actividades Económicas para Encuestas Sociodemográficas"@es ;
    dct:description "Clasificación de Actividades Económicas para Encuestas Sociodemográficas, versión 2018 (CAES 2018). Desarrollada por INDEC para su uso en encuestas a hogares (EPH, ENGHO, etc.), donde la actividad económica debe ser captada por encuestadores sin especialización estadística. Derivada conceptualmente del ClaNAE 2010 pero con estructura y nivel de detalle distintos."@es ;
    dct:source <https://www.indec.gob.ar/ftp/cuadros/menusuperior/clasificadores/caes_v2018.xls> ;
    dct:publisher <https://www.indec.gob.ar> ;
    dct:created "2018-01-01"^^xsd:date ;
    dct:modified "2018-01-01"^^xsd:date ;
    skos:note "La CAES no es directamente equivalente al ClaNAE a nivel de código: permite mapeos pero no correspondencias 1:1 en todos los niveles. Ver tabla de correspondencias oficial del INDEC."@es .

# Nota: los conceptos específicos de la CAES se agregarán en
# una versión futura a partir del XLS oficial
# https://www.indec.gob.ar/ftp/cuadros/menusuperior/clasificadores/caes_v2018.xls


